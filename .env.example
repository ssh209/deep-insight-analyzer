# ==========================================
# Issue Cracker — 환경변수 설정 템플릿
# 사용법: 이 파일을 .env로 복사하여 값을 입력하세요.
#   cp .env.example .env
# ==========================================

# --- GCP / Vertex AI ---
GCP_PROJECT_ID=deep-insight-496705
GCP_LOCATION=global
GEMINI_MODEL=gemini-2.5-pro

# --- 데이터 경로 ---
TRAIN_CSV_PATH=data/pr_crisis_dataset.csv
INPUT_CSV_PATH=data/input_crisis_72h.csv

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Database (외부 PostgreSQL 연결) ---
# 미설정 시 CSV 직접 입력 모드로 동작합니다.
# 아래 중 하나를 선택하여 주석 해제 후 값을 입력하세요.
#
# Neon:
# DATABASE_URL=postgresql://user:password@ep-xxx-yyy.ap-northeast-2.aws.neon.tech/issue_cracker?sslmode=require
#
# Supabase:
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
#
# Aurora Serverless v2:
# DATABASE_URL=postgresql://user:password@issue-cracker-cluster.cluster-xxx.ap-northeast-2.rds.amazonaws.com:5432/issue_cracker
#
로컬 개발:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibe_x

# DB 커넥션 풀 크기
# DB_MIN_CONNECTIONS=2
# DB_MAX_CONNECTIONS=10

# SSL 사용 여부 (클라우드 DB는 true 필수, 로컬은 false)
# DB_SSL=true
