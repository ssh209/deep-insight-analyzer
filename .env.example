# ==========================================
# Issue Cracker — 환경변수 설정 템플릿
# 사용법: 이 파일을 .env로 복사하여 값을 입력하세요.
#   cp .env.example .env
# ==========================================

# --- GCP / Vertex AI ---
GCP_PROJECT_ID=deep-insight-496705
GCP_LOCATION=global
GEMINI_MODEL=gemini-2.5-pro

# --- 에이전트별 LLM 모델 (멀티모델 전략) ---
# Flash: 고속·저비용 — 단순 분류, 지시서, 정량 비교
# Pro:   고추론·고품질 — 전략 수립, 리포트 융합, 뉘앙스 판별
FLASH_MODEL=gemini-2.5-flash
PRO_MODEL=gemini-2.5-pro

# QueryBuilder
# QUERY_BUILDER_GROUNDING_MODEL=gemini-2.5-pro
# QUERY_BUILDER_MODEL=gemini-2.5-flash

# Analyzer
# ANALYZER_MODEL=gemini-2.5-flash
# ANALYZER_DEEP_MODEL=gemini-2.5-pro

# Reporter 파이프라인
# PLANNER_MODEL=gemini-2.5-flash
# STRATEGIST_MODEL=gemini-2.5-pro
# ANALYST_MODEL=gemini-2.5-flash
# COMPILER_MODEL=gemini-2.5-pro
# REVIEWER_MODEL=gemini-2.5-pro

# --- 데이터 / 출력 경로 ---
TRAIN_CSV_PATH=data/pr_crisis_dataset.csv
INPUT_CSV_PATH=data/input_crisis_72h.csv
OUTPUT_DIR=output
REPORT_DIR=reports
LGBM_MODEL_PATH=models/lightgbm/nvi_forecaster.pkl
TFT_MODEL_PATH=models/tft/tft_nvi.ckpt

# --- Database (외부 PostgreSQL 연결) ---
# 미설정 시 CSV 직접 입력 모드로 동작합니다.
# 아래 중 하나를 선택하여 주석 해제 후 값을 입력하세요.
#
# Neon:
# DATABASE_URL=postgresql://user:password@ep-xxx-yyy.ap-northeast-2.aws.neon.tech/issue_cracker?sslmode=require
#
# Supabase:
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
#
# Aurora Serverless v2:
# DATABASE_URL=postgresql://user:password@issue-cracker-cluster.cluster-xxx.ap-northeast-2.rds.amazonaws.com:5432/issue_cracker
#
# 로컬 개발:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibe_x

# DB 커넥션 풀 크기
# DB_MIN_CONNECTIONS=2
# DB_MAX_CONNECTIONS=10

# SSL 사용 여부 (클라우드 DB는 true 필수, 로컬은 false)
# DB_SSL=true

# --- Embedding Model ---
# EMBEDDING_MODEL=intfloat/multilingual-e5-small
# EMBEDDING_DIM=384

# --- Forecaster Model ---
# "lightgbm" | "tft" | "moirai" | "arima"
FORECASTER_MODEL=lightgbm

# --- Report (HTML 보고서 → GCS 업로드) ---
# 비어있으면 로컬 저장만
GCS_REPORT_BUCKET=deep-insight-reports

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- LangSmith (LangGraph 트레이싱) ---
# LangSmith에서 API 키를 발급받아 입력하세요.
# https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your_api_key_here
LANGCHAIN_PROJECT=deep-insight-analyzer
