# ==========================================
# Issue Cracker — 환경변수 설정 템플릿
# 사용법: 이 파일을 .env로 복사하여 값을 입력하세요.
#   cp .env.example .env
# ==========================================

# --- GCP / Vertex AI ---
GCP_PROJECT_ID=deep-insight-496705
GCP_LOCATION=global
GEMINI_MODEL=gemini-2.5-pro

# --- 데이터 경로 ---
TRAIN_CSV_PATH=data/pr_crisis_dataset.csv
INPUT_CSV_PATH=data/input_crisis_72h.csv

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Database (Aurora Serverless 연동 시 주석 해제) ---
# DATABASE_URL=postgresql://user:password@host:5432/issue_cracker
